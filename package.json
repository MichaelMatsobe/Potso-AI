{
  "name": "potso-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "vite --port=3000 --host=0.0.0.0",
    "dev:server": "tsx watch server.ts",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "tsc server.ts --skipLibCheck",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "docker:build": "docker build -t potso-ai:latest .",
    "docker:run": "docker run -p 3000:3000 -p 8080:8080 --env-file .env.local potso-ai:latest"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "firebase": "^10.7.0",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-firebase-hooks": "^5.1.1",
    "three": "^0.183.2",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/uuid": "^9.0.7",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
